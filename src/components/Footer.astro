  youtube:  'M23.499 6.203a3.008 3.008 0 00-2.089-2.089c-1.87-.501-9.4-.501-9.4-.501s-7.509-.01-9.399.501A3.008 3.008 0 00.527 6.203a31.325 31.325 0 00-.522 5.805 31.325 31.325 0 00.522 5.783 3.008 3.008 0 002.085 2.088c1.868.502 9.396.502 9.396.502s7.506 0 9.396-.502a3.008 3.008 0 002.089-2.088 31.323 31.323 0 00.5-5.783 31.324 31.324 0 00-.5-5.805zM9.609 15.601V8.408l6.264 3.602z',
