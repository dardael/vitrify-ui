---
import type { FooterLink, FooterColumn, SocialIcon, SocialLink } from '../types'

type Props = {
  columns?: FooterColumn[]
  socials?:  SocialLink[]
  tagline?:  string
  theme?:    'light' | 'dark'
  legal?:    string
}

const {
  columns = [],
  socials  = [],
  tagline,
  theme   = 'light',
  legal,
} = Astro.props

const hasColumns = columns.length > 0
const hasSocials = socials.length > 0
const hasLegal   = Boolean(legal) || Astro.slots.has('legal')

