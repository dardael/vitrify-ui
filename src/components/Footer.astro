---

<footer class:list={['footer', `footer--${theme}`]}>
  <div class="footer__inner">

    <div class:list={['footer__top', !hasColumns && 'footer__top--brand-only']}>

      <div class="footer__brand">
        <div class="footer__logo">
          <slot name="logo" />
        </div>

        {tagline && (
          <p class="footer__tagline">{tagline}</p>
        )}

        {hasSocials && (
          <ul class="footer__socials" role="list" aria-label="Réseaux sociaux">
            {socials.map(s => (
              <li>
                <a
                  class="footer__social-link"
                  href={s.href}
                  aria-label={s.label}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  <svg
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    aria-hidden="true"
                    width="18"
                    height="18"
                  >
                    <path d={icons[s.icon]} />
                  </svg>
                </a>
              </li>
            ))}
          </ul>
        )}
      </div>

      {hasColumns && (
        <nav class="footer__nav" aria-label="Liens du pied de page">
          {columns.map(col => (
            <div class="footer__col">
              <p class="footer__col-heading">{col.heading}</p>
              <ul class="footer__col-links" role="list">
                {col.links.map(link => (
                  <li>
                    <a class="footer__link" href={link.href}>{link.label}</a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </nav>
      )}

    </div>

    {hasLegal && (
      <div class="footer__bottom">
        {legal && <p class="footer__legal">{legal}</p>}
        <slot name="legal" />
      </div>
    )}

  </div>
</footer>

<style>
  /* ── Theme tokens ── */
  .footer--light {
    --_bg:               var(--vf-color-background);
    --_border-top:       var(--vf-color-border);
    --_logo:             var(--vf-color-primary);
    --_tagline:          var(--vf-color-text-muted);
    --_col-heading:      var(--vf-color-text);
    --_link:             var(--vf-color-text-muted);
    --_link-hover:       var(--vf-color-primary);
    --_social:           var(--vf-color-text-subtle);
    --_social-hover:     var(--vf-color-primary);
    --_social-hover-bg:  var(--vf-color-surface);
    --_bottom-border:    var(--vf-color-border);
    --_legal:            var(--vf-color-text-subtle);
    --_focus:            var(--vf-color-primary);
    --_img-outline:      rgba(0, 0, 0, 0.1);
  }

  .footer--dark {
    --_bg:               var(--vf-color-primary);
    --_border-top:       var(--vf-color-on-primary-border);
    --_logo:             var(--vf-color-on-primary);
    --_tagline:          var(--vf-color-on-primary-muted);
    --_col-heading:      var(--vf-color-on-primary);
    --_link:             var(--vf-color-on-primary-muted);
    --_link-hover:       var(--vf-color-on-primary);
    --_social:           var(--vf-color-on-primary-muted);
    --_social-hover:     var(--vf-color-on-primary);
    --_social-hover-bg:  var(--vf-color-on-primary-subtle);
    --_bottom-border:    var(--vf-color-on-primary-border);
    --_legal:            var(--vf-color-on-primary-muted);
    --_focus:            var(--vf-color-on-primary);
    --_img-outline:      rgba(255, 255, 255, 0.1);
  }

  /* ── Base ── */
  .footer {
    background: var(--_bg);
    border-top: 1px solid var(--_border-top);
    width: 100%;
    font-family: var(--vf-font-sans);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  .footer__inner {
    max-width: var(--vf-container);
    margin: 0 auto;
    padding: 0 clamp(1rem, 5vw, 3rem);
  }

  /* ── Top block ── */
  .footer__top {
    display: flex;
    flex-direction: column;
    gap: var(--vf-spacing-12);
    padding: var(--vf-spacing-12) 0 var(--vf-spacing-8);
  }

  @media (min-width: 768px) {
    .footer__top {
      display: grid;
      grid-template-columns: 1fr 2fr;
      gap: var(--vf-spacing-16);
      padding: var(--vf-spacing-16) 0 var(--vf-spacing-12);
    }

    .footer__top--brand-only {
      grid-template-columns: 1fr;
    }
  }

  /* ── Brand column ── */
  .footer__brand {
    display: flex;
    flex-direction: column;
    gap: var(--vf-spacing-4);
  }

  .footer__logo :global(a) {
    font-family: var(--vf-font-display);
    font-variation-settings: var(--vf-font-display-settings);
    font-size: var(--vf-font-size-lg);
    font-weight: 700;
    letter-spacing: -0.025em;
    text-decoration: none;
    color: var(--_logo);
    display: inline-flex;
    align-items: center;
    gap: var(--vf-spacing-2);
    line-height: 1;
  }

  .footer__logo :global(img) {
    max-height: 28px;
    width: auto;
    outline: 1px solid var(--_img-outline);
    outline-offset: -1px;
  }

  .footer__logo :global(a:focus-visible) {
    outline: 2px solid var(--_focus);
    outline-offset: 3px;
    border-radius: var(--vf-radius-sm);
  }

  .footer__tagline {
    font-size: var(--vf-font-size-sm);
    line-height: var(--vf-line-height-relaxed);
    color: var(--_tagline);
    max-width: 28ch;
    margin: 0;
    text-wrap: pretty;
  }

  /* ── Socials ── */
  .footer__socials {
    display: flex;
    flex-wrap: wrap;
    gap: var(--vf-spacing-1);
    list-style: none;
    margin: var(--vf-spacing-2) 0 0;
    padding: 0;
  }

  .footer__social-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: var(--vf-radius-md);
    color: var(--_social);
    text-decoration: none;
    transition:
      color            var(--vf-duration-fast) var(--vf-ease-out),
      background-color var(--vf-duration-fast) var(--vf-ease-out),
      transform        var(--vf-duration-fast) var(--vf-ease-out);
  }

  .footer__social-link:hover {
    color: var(--_social-hover);
    background-color: var(--_social-hover-bg);
  }

  .footer__social-link:active {
    transform: scale(0.96);
  }

  .footer__social-link:focus-visible {
    outline: 2px solid var(--_focus);
    outline-offset: 2px;
  }

  /* ── Nav columns ── */
  .footer__nav {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(130px, 1fr));
    gap: var(--vf-spacing-8) var(--vf-spacing-6);
    align-content: start;
  }

  .footer__col {
    display: flex;
    flex-direction: column;
  }

  .footer__col-heading {
    font-size: var(--vf-font-size-xs);
    font-weight: var(--vf-font-weight-semibold);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--_col-heading);
    margin: 0 0 var(--vf-spacing-3);
  }

  .footer__col-links {
    display: flex;
    flex-direction: column;
    gap: 0;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .footer__link {
    display: flex;
    align-items: center;
    min-height: 44px;
    font-size: var(--vf-font-size-sm);
    line-height: var(--vf-line-height-normal);
    color: var(--_link);
    text-decoration: none;
    transition: color var(--vf-duration-fast) var(--vf-ease-out);
  }

  @media (min-width: 768px) {
    .footer__col-links {
      gap: var(--vf-spacing-3);
    }

    .footer__link {
      display: block;
      min-height: unset;
    }
  }

  .footer__link:hover {
    color: var(--_link-hover);
  }

  .footer__link:focus-visible {
    outline: 2px solid var(--_focus);
    outline-offset: 2px;
    border-radius: 2px;
  }

  /* ── Bottom / legal strip ── */
  .footer__bottom {
    border-top: 1px solid var(--_bottom-border);
    padding: var(--vf-spacing-6) 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--vf-spacing-3) var(--vf-spacing-6);
    align-items: center;
    justify-content: space-between;
  }

  .footer__legal {
    font-size: var(--vf-font-size-xs);
    color: var(--_legal);
    margin: 0;
    line-height: var(--vf-line-height-normal);
  }

  /* Legal slot content (links, extra text) */
  .footer__bottom :global(a) {
    font-size: var(--vf-font-size-xs);
    color: var(--_legal);
    text-decoration: none;
    transition: color var(--vf-duration-fast) var(--vf-ease-out);
  }

  .footer__bottom :global(a:hover) {
    color: var(--_link-hover);
  }

  .footer__bottom :global(nav) {
    display: flex;
    flex-wrap: wrap;
    gap: var(--vf-spacing-4);
    align-items: center;
  }

  /* ── Reduced motion ── */
  @media (prefers-reduced-motion: reduce) {
    .footer__social-link,
    .footer__link,
    .footer__bottom :global(a) {
      transition: none;
    }
  }
</style>
