---
import ShowcaseLayout from '../layouts/ShowcaseLayout.astro'

const componentPaths = Object.keys(import.meta.glob('./components/*.astro'))
const templatePaths = Object.keys(import.meta.glob('./templates/*.astro'))

const toName = (path: string) =>
  path.split('/').pop()?.replace('.astro', '') ?? path

const toHref = (path: string) =>
  path.replace(/^\./, '').replace('.astro', '')
---

<ShowcaseLayout title="Vitrify — Showcase">
  <main class="page">
    <h1>Vitrify Showcase</h1>

    <h2>Composants</h2>
    {componentPaths.length > 0 ? (
      <div class="grid">
        {componentPaths.map((p) => (
          <a class="card" href={toHref(p)}>{toName(p)}</a>
        ))}
      </div>
    ) : (
      <p class="empty">
        Aucun composant — créer des pages dans <code>src/pages/components/</code>
      </p>
    )}

    <h2>Templates</h2>
    {templatePaths.length > 0 ? (
      <div class="grid">
        {templatePaths.map((p) => (
          <a class="card" href={toHref(p)}>{toName(p)}</a>
        ))}
      </div>
    ) : (
      <p class="empty">
        Aucun template — créer des pages dans <code>src/pages/templates/</code>
      </p>
    )}
  </main>
</ShowcaseLayout>

<style>
  .page {
    padding: var(--vf-spacing-8);
  }

  h1 {
    font-size: var(--vf-font-size-heading);
    margin-bottom: var(--vf-spacing-2);
  }

  h2 {
    font-size: var(--vf-font-size-xl);
    margin: var(--vf-spacing-8) 0 var(--vf-spacing-4);
    color: var(--vf-color-text-muted);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: var(--vf-spacing-4);
  }

  .card {
    display: block;
    padding: var(--vf-spacing-4) var(--vf-spacing-6);
    background: var(--vf-color-surface);
    border: 1px solid var(--vf-color-border);
    border-radius: var(--vf-radius-md);
    text-decoration: none;
    color: var(--vf-color-text);
    font-weight: var(--vf-font-weight-medium);
    transition: box-shadow var(--vf-duration-fast) var(--vf-ease-out);
  }

  .card:hover { box-shadow: var(--vf-shadow-md); }

  .empty {
    color: var(--vf-color-text-subtle);
    font-size: var(--vf-font-size-sm);
  }
</style>
