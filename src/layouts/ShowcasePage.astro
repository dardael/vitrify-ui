---
import ShowcaseLayout from './ShowcaseLayout.astro'

interface Props {
  component: string
}

const { component } = Astro.props
---

<ShowcaseLayout title={`${component} — Vitrify Showcase`}>

  <nav class="nav" aria-label="Navigation showcase">
    <a href="/" class="nav-back">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
        <path d="M9 2L4 7l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      Showcase
    </a>
    <span class="nav-sep" aria-hidden="true">/</span>
    <span class="nav-title">{component}</span>
  </nav>

  <slot />

</ShowcaseLayout>

<style>
  /* ── Nav (scoped to this layout's own elements) ── */
  .nav {
    display: flex;
    align-items: center;
    gap: var(--vf-spacing-4);
    padding: var(--vf-spacing-4) var(--vf-spacing-8);
    border-bottom: 1px solid var(--vf-color-border);
  }

  .nav-back {
    font-size: var(--vf-font-size-sm);
    color: var(--vf-color-text-muted);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: var(--vf-spacing-2);
    transition: color var(--vf-duration-fast) var(--vf-ease-out);
  }

  .nav-back:hover { color: var(--vf-color-primary); }

  .nav-sep {
    color: var(--vf-color-border);
    font-size: var(--vf-font-size-sm);
  }

  .nav-title {
    font-size: var(--vf-font-size-sm);
    font-weight: var(--vf-font-weight-semibold);
    color: var(--vf-color-text);
  }

  @media (max-width: 600px) {
    .nav { padding: var(--vf-spacing-3) var(--vf-spacing-4); }
  }
</style>

<style is:global>
  /* ── Shared showcase utilities ──
     All showcase pages use ShowcasePage, so shared layout and component
     styles live here instead of being duplicated per page.
  ── */

  /* Container */
  .container {
    max-width: var(--vf-container);
    margin: 0 auto;
    padding: 0 clamp(1rem, 5vw, 3rem);
  }

  /* Page header */
  .page-header {
    padding: var(--vf-spacing-12) 0 var(--vf-spacing-8);
    border-bottom: 1px solid var(--vf-color-border);
  }

  .page-header h1 {
    font-size: var(--vf-font-size-heading);
    font-weight: var(--vf-font-weight-bold);
    font-variation-settings: var(--vf-font-display-settings);
    letter-spacing: -0.02em;
    margin-bottom: var(--vf-spacing-3);
    text-wrap: balance;
  }

  .page-header p {
    font-size: var(--vf-font-size-base);
    color: var(--vf-color-text-muted);
    max-width: 60ch;
    line-height: var(--vf-line-height-relaxed);
  }

  .page-header code {
    font-family: var(--vf-font-mono);
    font-size: 0.85em;
  }

  /* Variant blocks */
  .variant-block { padding-top: var(--vf-spacing-8); }
  .variant-block--bordered { border-top: 1px solid var(--vf-color-border); }

  .variant-label {
    font-size: var(--vf-font-size-xs);
    font-weight: var(--vf-font-weight-semibold);
    color: var(--vf-color-text-subtle);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: var(--vf-spacing-4);
  }

  /* Props & Usage content area */
  .page {
    max-width: var(--vf-container);
    margin: 0 auto;
    padding: var(--vf-spacing-16) clamp(1rem, 5vw, 3rem);
  }

  .section {
    margin-bottom: var(--vf-spacing-16);
  }

  .section-label {
    font-size: var(--vf-font-size-sm);
    font-weight: var(--vf-font-weight-semibold);
    color: var(--vf-color-text-muted);
    margin-bottom: var(--vf-spacing-6);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .code-block {
    background: var(--vf-color-surface);
    border: 1px solid var(--vf-color-border);
    border-radius: var(--vf-radius-md);
    padding: var(--vf-spacing-6);
    font-family: var(--vf-font-mono);
    font-size: var(--vf-font-size-sm);
    color: var(--vf-color-text);
    line-height: var(--vf-line-height-relaxed);
    overflow-x: auto;
    white-space: pre;
  }

  /* Props tables */
  .props-table-wrap {
    overflow-x: auto;
    border: 1px solid var(--vf-color-border);
    border-radius: var(--vf-radius-md);
  }

  .props-table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--vf-font-size-sm);
    min-width: 520px;
  }

  .props-table th {
    text-align: left;
    padding: var(--vf-spacing-3) var(--vf-spacing-4);
    background: var(--vf-color-surface);
    color: var(--vf-color-text-muted);
    font-weight: var(--vf-font-weight-semibold);
    font-size: var(--vf-font-size-xs);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    border-bottom: 1px solid var(--vf-color-border);
  }

  .props-table td {
    padding: var(--vf-spacing-3) var(--vf-spacing-4);
    color: var(--vf-color-text);
    line-height: var(--vf-line-height-relaxed);
    border-bottom: 1px solid var(--vf-color-border);
    vertical-align: top;
  }

  .props-table tr:last-child td { border-bottom: none; }

  .props-table code {
    font-family: var(--vf-font-mono);
    font-size: 0.8em;
    background: var(--vf-color-surface);
    border: 1px solid var(--vf-color-border);
    border-radius: var(--vf-radius-sm);
    padding: 1px 5px;
    color: var(--vf-color-primary);
  }

  /* Mobile */
  @media (max-width: 600px) {
    .page-header { padding: var(--vf-spacing-8) 0 var(--vf-spacing-6); }
    .page { padding: var(--vf-spacing-10) clamp(1rem, 5vw, 3rem); }
  }
</style>
